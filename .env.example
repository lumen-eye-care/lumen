# Lumen Eye Care — environment template.
# Copy to .env.local and fill in. NEVER commit real values (.env.local is gitignored).

# --- Supabase (public; safe to expose, RLS-protected) ---
# New-format publishable key (sb_publishable_…) — replaces the legacy anon key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# --- Supabase (server-only; bypasses RLS — never expose to the client) ---
# New-format secret key (sb_secret_…) — replaces the legacy service_role key.
SUPABASE_SECRET_KEY=

# --- Paystack ---
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=

# --- Resend (server-only) ---
RESEND_API_KEY=

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Feature flags ---
# Stays false until the lens-fulfillment partner is named and DPC registration completes.
LUMEN_PRESCRIPTION_UPLOAD_ENABLED=false

# --- Admin ---
# Comma-separated email domains that get the admin role on signup (Tier 2 simplification).
ADMIN_EMAIL_DOMAINS=
