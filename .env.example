# Lumen Eye Care — environment template.
# Copy to .env.local and fill in. NEVER commit real values (.env.local is gitignored).

# --- Supabase (public; safe to expose, RLS-protected) ---
# New-format publishable key (sb_publishable_…) — replaces the legacy anon key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# --- Supabase (server-only; bypasses RLS — never expose to the client) ---
# New-format secret key (sb_secret_…) — replaces the legacy service_role key.
SUPABASE_SECRET_KEY=

# --- Paystack ---
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=

# --- Resend (server-only) ---
RESEND_API_KEY=

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Observability: Sentry (free tier) ---
# DSN is public by design (only permits *sending* events). Leave blank to disable
# Sentry locally — the SDK no-ops without it.
NEXT_PUBLIC_SENTRY_DSN=
# Build-only. SENTRY_AUTH_TOKEN is a SECRET (source-map upload) — set it in the
# Vercel *build* env, never as NEXT_PUBLIC_, never commit it. Org/project are not
# secret. All three are only needed at `next build` time.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
# Vercel Analytics + Speed Insights need NO env vars (enabled in the dashboard).

# --- Rate limiting: Upstash Redis (free tier) ---
# Powers sign-in / signup / password-reset / checkout-initiate limits
# (security audit 2.4). Leave blank to disable — the limiter no-ops without
# them. TOKEN is a SECRET (server-only, never NEXT_PUBLIC_).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Feature flags ---
# Stays false until the lens-fulfillment partner is named and DPC registration completes.
LUMEN_PRESCRIPTION_UPLOAD_ENABLED=false
# Phase-3 POC: PDP 3D/AR <model-viewer> preview. Defaults OFF (stays off live
# products until real per-frame .glb models exist). Set true to demo on staging.
NEXT_PUBLIC_DEMO_3D_ENABLED=false

# --- Admin ---
# Comma-separated email domains that get the admin role on signup (Tier 2 simplification).
ADMIN_EMAIL_DOMAINS=

# --- Appointments (US-P1-01) ---
# Ops inbox for admin notification emails when a new appointment request is
# submitted. Optional — customer confirmation still sends; admin email is skipped.
APPOINTMENTS_NOTIFY_EMAIL=

# --- Seed (dev only) ---
# `pnpm seed` creates this admin user (app_metadata.role=admin) + mock orders so
# the /admin surface is testable. Leave unset to skip. NEVER use real prod creds.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
