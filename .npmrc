# Hoist Sentry + OpenTelemetry to the root node_modules. The @sentry/nextjs
# server/edge SDK requires('@sentry/opentelemetry') as a transitive dep;
# Turbopack (build + dev) can't resolve it through pnpm's nested symlink
# layout on Windows worktrees ("Module not found: Can't resolve
# '@sentry/opentelemetry'"). Hoisting makes it resolvable without changing
# any versions.
public-hoist-pattern[]=*@sentry/*
public-hoist-pattern[]=*@opentelemetry/*
