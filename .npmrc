# Flat (hoisted) node_modules — every package is a real top-level directory, no
# .pnpm symlink store. The @sentry/nextjs server/edge SDK requires the transitive
# '@sentry/opentelemetry'; Turbopack (build + dev) cannot follow pnpm's default
# nested symlink layout for it on Windows worktrees ("Module not found: Can't
# resolve '@sentry/opentelemetry'"). A flat layout resolves natively. The earlier
# public-hoist-pattern workaround did not reliably fix Turbopack resolution.
node-linker=hoisted
